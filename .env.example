# ─────────────────────────────────────────────────────────────────────────────
# Perú Calcula — Variables de entorno de PRODUCCIÓN
# Copia este archivo como .env en el servidor y rellena los valores reales.
# NUNCA commitear .env con valores reales al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker / Registry ─────────────────────────────────────────────────────────
# Reemplaza con tu usuario de GitHub (owner del repositorio)
REGISTRY=ghcr.io/TU_USUARIO_GITHUB
IMAGE_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=peru_calcula
POSTGRES_USER=peru_calcula_app
# Generar con: openssl rand -base64 24
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI

# Connection string completa (usada por la API .NET)
DB_CONNECTION_STRING=Host=db;Database=peru_calcula;Username=peru_calcula_app;Password=CAMBIAR_PASSWORD_SEGURO_AQUI;Pooling=true;Maximum Pool Size=20

# ── JWT ───────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios
# Generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_CLAVE_JWT_MINIMO_32_CHARS_ALEATORIA_AQUI

# ── URLs ──────────────────────────────────────────────────────────────────────
WEB_URL=https://perucalcula.pe
